# Database (SQLite — works locally and on Vercel)
DATABASE_URL=file:./db/custom.db

# ── AI Provider Keys (at least one required) ──────────────
# OpenRouter (RECOMMENDED — free models, works globally)
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Groq API (fast, free tier)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini API (may have geo-restrictions)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
